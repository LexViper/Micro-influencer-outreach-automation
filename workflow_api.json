      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\nconst response = item.text || item.response || item.output || '';\nlet parsed;\ntry {\n  const clean = response.replace(/```json|```/g, '').trim();\n  parsed = JSON.parse(clean);\n} catch(e) {\n  parsed = { emailPitch: 'Generation failed. Retry.', instagramDM: 'Generation failed. Retry.' };\n}\nreturn {\n  ...item,\n  emailPitch: parsed.emailPitch || '',\n  instagramDM: parsed.instagramDM || ''\n};"
      },
