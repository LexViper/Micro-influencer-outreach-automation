      "parameters": {
        "promptType": "define",
        "text": "=You are an influencer marketing outreach specialist working for an Indian wellness brand.\n\nInfluencer Details:\n- Name: {{ $json.name }}\n- Platform: {{ $json.platform }}\n- Followers: {{ $json.followers }}\n- Engagement Rate: {{ $json.engagementRate }}%\n- Niche: {{ $json.niche }}\n- Content Themes: {{ $json.contentThemes }}\n- City: {{ $json.city }}\n- Segment: {{ $json.segment }}\n- Collaboration Type: {{ $json.collaborationType }}\n- Bio: {{ $json.bio }}\n\nGenerate two outreach messages. Return ONLY a raw JSON object, no markdown:\n\n{\n  \"emailPitch\": \"60-90 words. Professional tone. Reference their niche, themes and engagement. Mention the collaboration type.\",\n  \"instagramDM\": \"15-30 words. Casual and direct. Reference their content.\"\n}"
      },
