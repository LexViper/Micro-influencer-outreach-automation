    {
      "parameters": {
        "jsCode": "const blocklist = ['dogsofinstagram','greatpetcare','dogs','pets','catsofinstagram','cat','dog','animal','rescue','petcare'];\nconst seen = new Set();\nconst unique = [];\nfor (const item of $input.all()) {\n  const username = item.json.ownerUsername || item.json.username || item.json.owner?.username;\n  \n  if (!username || username.trim() === '') continue;\n  \n  if (!seen.has(username) && !blocklist.some(b => username.toLowerCase().includes(b))) {\n    seen.add(username);\n    unique.push({ json: { username } });\n  }\n  if (unique.length >= 20) break;\n}\nif (unique.length === 0) {\n  throw new Error('No valid influencer usernames found - all profiles were filtered out');\n}\nreturn unique;"
      },
      "id": "20eafe3d-7e00-4708-a78f-496f38e014c1",
      "name": "Deduplicate Usernames",
